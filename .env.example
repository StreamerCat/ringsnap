# ═══════════════════════════════════════════════════════════════
# RINGSNAP MVP - ENVIRONMENT CONFIGURATION
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your actual values
# Keep .env private - never commit to version control
# ═══════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────
# FRONTEND (Public - VITE_ prefix required)
# ───────────────────────────────────────────────────────────────

# Stripe - Frontend
VITE_STRIPE_PUBLISHABLE_KEY="pk_test_your_publishable_key_here"

# Supabase - Frontend
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_PROJECT_ID="your-project-ref"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"

# Bot Access (Optional - for automated testing)
VITE_JULES_SECRET="your-secure-random-secret-here"

# ───────────────────────────────────────────────────────────────
# BACKEND (Server-side - Edge Functions)
# ───────────────────────────────────────────────────────────────

# Supabase - Backend
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Vapi AI Platform
VAPI_API_KEY="your-vapi-api-key"
VAPI_BASE_URL="https://api.vapi.ai"

# Vapi Web Widget (Public)
VITE_VAPI_PUBLIC_KEY="your-public-key"
VITE_VAPI_WIDGET_ASSISTANT_ID="your-assistant-id"

# Stripe - Backend
STRIPE_SECRET_KEY="sk_test_your_secret_key_here"
STRIPE_PRICE_STARTER="price_starter_plan_id"
STRIPE_PRICE_PROFESSIONAL="price_professional_plan_id"
STRIPE_PRICE_PREMIUM="price_premium_plan_id"

# Resend.com Email (Auth System)
# Preferred production key consumed by edge functions
RESEND_PROD_KEY="re_your_resend_api_key"
# Legacy fallback for backwards compatibility
# RESEND_API_KEY="re_your_legacy_api_key"
EMAIL_FROM="RingSnap <noreply@getringsnap.com>"
EMAIL_REPLY_TO="support@getringsnap.com"
EMAIL_STREAM="transactional"

# Twilio SMS (Appointment Notifications)
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your_twilio_auth_token"
TWILIO_PHONE_NUMBER="+15551234567"

# Auth Configuration
SITE_URL="http://localhost:5173"
AUTH_MAGIC_LINK_TTL_MINUTES="20"
AUTH_INVITE_TTL_HOURS="48"

# Bot Access Secret
# Used by automated testing tools (e.g., Google Jules) to bypass password gate
# Generate a secure random string for production
VITE_JULES_SECRET="your-secure-random-secret-here"
