# ═══════════════════════════════════════════════════════════════
# RINGSNAP MVP - ENVIRONMENT CONFIGURATION
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your actual values
# Keep .env private - never commit to version control
# ═══════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────
# FRONTEND (Public - VITE_ prefix required)
# ───────────────────────────────────────────────────────────────

# PostHog - Analytics (Frontend)
VITE_POSTHOG_KEY="phc_your_posthog_project_api_key_here"
VITE_POSTHOG_HOST="https://us.i.posthog.com"

# Stripe - Frontend
VITE_STRIPE_PUBLISHABLE_KEY="pk_test_your_publishable_key_here"

# Supabase - Frontend
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_PROJECT_ID="your-project-ref"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"

# Bot Access (Optional - for automated testing)
VITE_JULES_SECRET="your-secure-random-secret-here"

# ───────────────────────────────────────────────────────────────
# BACKEND (Server-side - Edge Functions)
# ───────────────────────────────────────────────────────────────

# Supabase - Backend
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Vapi AI Platform
VAPI_API_KEY="your-vapi-api-key"
VAPI_BASE_URL="https://api.vapi.ai"

# Vapi Web Widget (Public)
VITE_VAPI_PUBLIC_KEY="your-public-key"
VITE_VAPI_WIDGET_ASSISTANT_ID="your-assistant-id"

# Stripe - Backend
STRIPE_SECRET_KEY="sk_test_your_secret_key_here"

# Stripe — new plan base price IDs (populate after running scripts/stripe-setup-new-plans.js)
STRIPE_PRICE_ID_NIGHT_WEEKEND=
STRIPE_PRICE_ID_LITE=
STRIPE_PRICE_ID_CORE=
STRIPE_PRICE_ID_PRO=

# Stripe — metered overage price IDs (same script above)
STRIPE_OVERAGE_PRICE_ID_NIGHT_WEEKEND=
STRIPE_OVERAGE_PRICE_ID_LITE=
STRIPE_OVERAGE_PRICE_ID_CORE=
STRIPE_OVERAGE_PRICE_ID_PRO=

# Old price IDs to archive (fill in from Stripe dashboard before running setup script)
STRIPE_OLD_PRICE_ID_STARTER=
STRIPE_OLD_PRICE_ID_PROFESSIONAL=
STRIPE_OLD_PRICE_ID_PREMIUM=

# Legacy price IDs (kept for backward compatibility — no longer used for new signups)
STRIPE_PRICE_STARTER_OLD="price_starter_plan_id"
STRIPE_PRICE_PROFESSIONAL_OLD="price_professional_plan_id"
STRIPE_PRICE_PREMIUM_OLD="price_premium_plan_id"

# PostHog - Analytics (Backend / Edge Functions)
# Server-side key for PostHog capture in Edge Functions (vapi-webhook, stripe-webhook)
POSTHOG_API_KEY="phx_your_server_side_posthog_key_here"
# Shared secret for posthog-signal Edge Function authentication
# Generate with: openssl rand -hex 32
POSTHOG_SIGNAL_SECRET="your-secure-random-32-char-secret-here"

# Resend.com Email (Auth System)
# Preferred production key consumed by edge functions
RESEND_PROD_KEY="re_your_resend_api_key"
# Legacy fallback for backwards compatibility
# RESEND_API_KEY="re_your_legacy_api_key"
EMAIL_FROM="RingSnap <noreply@getringsnap.com>"
EMAIL_REPLY_TO="support@getringsnap.com"
EMAIL_STREAM="transactional"

# Twilio SMS (Appointment Notifications)
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your_twilio_auth_token"
TWILIO_PHONE_NUMBER="+15551234567"

# Auth Configuration
SITE_URL="http://localhost:5173"
AUTH_MAGIC_LINK_TTL_MINUTES="20"
AUTH_INVITE_TTL_HOURS="48"

# Bot Access Secret
# Used by automated testing tools (e.g., Google Jules) to bypass password gate
# Generate a secure random string for production
VITE_JULES_SECRET="your-secure-random-secret-here"
