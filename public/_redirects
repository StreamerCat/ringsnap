# NOTE:
# Do not force slash-removal redirects here.
# Netlify Pretty URLs may redirect path forms internally, and adding explicit
# trailing-slash rewrites can create redirect loops on pages like /pricing
# and /difference in some hosting setups.

# Legacy signup routes — server-side 301 so bots don't need JS to follow the redirect
/signup          /start          301
/signup/form     /start          301
/onboarding      /onboarding-chat 301

# Sitemap aliases (avoid SPA fallback returning HTML)
/sitemap             /sitemap.xml       301
/sitemap_index.xml   /sitemap.xml       301
/sitemap.xml         /sitemap.xml       200

# SPA fallback - must be last
/*    /index.html   200
