# Frontend Supabase vars (Vite)
VITE_SUPABASE_URL="https://test.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="test-anon-key"

# Go-live test environment (safe defaults)
TEST_MODE=true
TEST_NAMESPACE=go-live
GO_LIVE_USE_MOCKS=true

# App + Playwright
PLAYWRIGHT_BASE_URL=http://localhost:8080

# Supabase (local or staging, never production)
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Optional auth credentials for dashboard smoke (staging/local test user)
TEST_USER_EMAIL=
TEST_USER_PASSWORD=

# Stripe test-mode only
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_STARTER=price_xxx
STRIPE_PRICE_PROFESSIONAL=price_xxx
STRIPE_PRICE_PREMIUM=price_xxx

# VAPI test project/key or leave blank to run with mocked integration tests
VAPI_API_KEY=
VAPI_BASE_URL=https://api.vapi.ai
VAPI_WEBHOOK_SECRET=

# Calendar provider (mocked by default in tests)
CALENDAR_PROVIDER=mock
