# RingSnap Ops Flow — Environment Variables
# Copy to .env and fill in real values before running.
# Never commit .env to git.
# All adapters run in stub mode when credentials are missing.

# =============================================================================
# REQUIRED: LLM (for CrewAI crew execution)
# =============================================================================
ANTHROPIC_API_KEY=sk-ant-...

# =============================================================================
# REQUIRED: Supabase (shared database with existing RingSnap app)
# =============================================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # Service role key — never expose to browser

# =============================================================================
# REQUIRED: Stripe (checkout session creation + webhook verification)
# =============================================================================
STRIPE_SECRET_KEY=sk_live_...     # or sk_test_... for staging
STRIPE_OPS_WEBHOOK_SECRET=whsec_... # Webhook signing secret for ops service

# =============================================================================
# REQUIRED: Internal webhook secret
# Set this in the Supabase Edge Function that forwards events to ops service
# =============================================================================
OPS_WEBHOOK_SECRET=your-secret-here

# =============================================================================
# OPTIONAL: Twilio (SMS checkout link delivery)
# System works without this — SMS sending will be skipped (stub mode)
# =============================================================================
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM_NUMBER=+1...

# =============================================================================
# OPTIONAL: Resend (email checkout link delivery)
# =============================================================================
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=ops@ringsnap.com

# =============================================================================
# OPTIONAL: Vapi (for sending tool responses back during calls)
# =============================================================================
VAPI_API_KEY=...
VAPI_WEBHOOK_SECRET=...

# =============================================================================
# SERVICE CONFIGURATION
# =============================================================================

# "development" | "staging" | "production"
ENVIRONMENT=development

# Set to "false" to disable all ops flow processing without stopping the service
# This is the quick toggle for rollback without code changes
OPS_FLOW_ENABLED=true

# Port for the FastAPI server
PORT=8080
