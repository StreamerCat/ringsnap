# Phone Provisioning Configuration
# Copy this file to .env.local and fill in your actual values

# ============================================================
# VAPI Configuration
# ============================================================
# Your Vapi API key from https://dashboard.vapi.ai
# Get this from Vapi dashboard settings
VAPI_API_KEY=sk_...

# ============================================================
# Supabase Configuration
# ============================================================
# Your Supabase project URL
SUPABASE_URL=https://your-project.supabase.co

# Service role key (server-side only - NEVER expose to frontend)
# Get this from Supabase dashboard -> Project Settings -> API
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ============================================================
# Email Configuration
# ============================================================
# Choose ONE email provider below:

# Option 1: SendGrid
SENDGRID_API_KEY=SG.xxxx...

# Option 2: Resend
# RESEND_PROD_KEY=re_xxxx...  # preferred
# RESEND_API_KEY=re_xxxx...   # legacy fallback if PROD key unavailable

# Email from address (used in phone provisioning notifications)
NOTIFY_EMAIL_FROM=noreply@getringsnap.com

# ============================================================
# SMS Configuration (Twilio)
# ============================================================
# Get these from https://www.twilio.com/console
TWILIO_ACCOUNT_SID=ACxxxx...
TWILIO_AUTH_TOKEN=xxxx...
NOTIFY_SMS_FROM=+1234567890

# ============================================================
# Application Settings
# ============================================================
# Your application's base URL (used in notification links)
APP_URL=https://app.getringsnap.com

# ============================================================
# Optional: Custom Webhook for Phone Ready Notifications
# ============================================================
# If you want to handle phone_ready events in your own backend
# NOTIFY_WEBHOOK_URL=https://your-api.com/webhooks/phone-ready
