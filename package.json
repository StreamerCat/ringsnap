  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && npm run build:sitemap && npm run build:prerender",
    "build:sitemap": "node scripts/generate-sitemap.js",
    "build:prerender": "node scripts/prerender.mjs",
    "build:no-prerender": "vite build && npm run build:sitemap",
    "build:dev": "vite build --mode development",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "typecheck": "tsc --noEmit",
    "test:voice-demo": "bash scripts/test-voice-demo.sh",
    "test:vapi-demo": "bash scripts/test-voice-demo.sh",
    "audit:perf": "echo 'Run: npx lighthouse <url> --output json --output-path ./audit-report.json' # Placeholder for agent",
    "audit:seo": "echo 'Run: npx lighthouse <url> --only-categories=seo'",
    "audit:a11y": "echo 'Run: npx axe <url>'",
    "test:lhci": "lhci autorun",
    "test:smoke": "playwright test --project=smoke",
    "test:smoke:api": "playwright test --project=smoke --reporter=github",
    "test:smoke:ci": "playwright test --project=smoke --reporter=github",
    "test:provisioning:e2e": "node scripts/provisioning-e2e-agent.mjs",
    "test:full": "playwright test --project=full",
    "test:signup-critical": "vitest run tests/signup-critical && node scripts/provisioning-e2e-agent.mjs",
    "check:robots": "node scripts/check-robots.mjs",
    "check:sitemap": "node scripts/check-sitemap-coverage.mjs",
    "check:seo": "npm run check:robots && npm run check:sitemap && npm run check:sitemap-serving",
    "test:billing": "node scripts/billing-smoke/run.mjs",
    "stripe:list-price-env": "bash scripts/stripe-list-price-env-vars.sh",
    "test:go-live:integration": "vitest run tests/go-live",
    "test:go-live:e2e": "playwright test --project=smoke tests/e2e/go-live/smoke.spec.ts",
    "test:go-live": "node scripts/run-go-live-tests.mjs",
    "check:sitemap-serving": "node scripts/check-sitemap-serving.mjs"
